modules = ["python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start MADARA MUSIC Bot"

[[workflows.workflow]]
name = "Start MADARA MUSIC Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip install -r requirements.txt -q && python3 -m MADARAMUSIC"

[workflows.workflow.metadata]
outputType = "console"
